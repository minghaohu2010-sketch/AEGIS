import os
import torch
import pandas as pd
import numpy as np
from PIL import Image
from torch.utils.data import Dataset, DataLoader
import torch.nn as nn
import torch.nn.functional as F
import torchvision.models as models
import torchvision.transforms as transforms
from torch.optim import Adam
from sklearn.model_selection import train_test_split
from tqdm import tqdm
import random
from collections import Counter

OUTPUT_DIR = 'reward_model_v2m'
os.makedirs(OUTPUT_DIR, exist_ok=True)

def set_seed(seed=42):
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed(seed)
        torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False

set_seed()

IMAGE_DIR   = 'test_output'
EXCEL_PATH  = 'manual_rating.xlsx'
BATCH_SIZE  = 16
NUM_EPOCHS  = 150
LEARNING_RATE = 0.0001
DEVICE      = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
MIXUP_ALPHA = 0.3
MIXUP_PROB  = 0.5

class CTImageDataset(Dataset):
    def __init__(self, df, img_dir, transform=None):
        self.df        = df
        self.img_dir   = img_dir
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        img_name = self.df.iloc[idx]['file_name']
        if not img_name.endswith('.png'):
            img_name = f"{img_name}.png"
        image = Image.open(os.path.join(self.img_dir, img_name)).convert('RGB')
        if self.transform:
            image = self.transform(image)
        score = self.df.iloc[idx]['score']
        return image, torch.tensor(score, dtype=torch.float32)

class EfficientNetV2RewardModel(nn.Module):
    def __init__(self, score_range=(1, 10)):
        super(EfficientNetV2RewardModel, self).__init__()
        self.score_min, self.score_max = score_range

        self.feature_extractor = models.efficientnet_v2_m(
            weights=models.EfficientNet_V2_M_Weights.DEFAULT
        )
        self.feature_extractor.classifier = nn.Identity()

        self.score_predictor = nn.Sequential(
            nn.Linear(1280, 512),
            nn.LeakyReLU(0.2),
            nn.BatchNorm1d(512),
            nn.Dropout(0.5),
            nn.Linear(512, 128),
            nn.LeakyReLU(0.2),
            nn.BatchNorm1d(128),
            nn.Dropout(0.2),
            nn.Linear(128, 32),
            nn.LeakyReLU(0.2),
            nn.Linear(32, 1),
        )

        for m in self.score_predictor.modules():
            if isinstance(m, nn.Linear):
                nn.init.kaiming_normal_(m.weight, nonlinearity='leaky_relu')
                if m.bias is not None:
                    nn.init.constant_(m.bias, 0)

        with torch.no_grad():
            last_layer = list(self.score_predictor.children())[-1]
            last_layer.weight.data += torch.randn_like(last_layer.weight.data) * 0.1
            if last_layer.bias is not None:
                last_layer.bias.data += torch.randn_like(last_layer.bias.data) * 0.1

    def forward(self, x):
        return self.score_predictor(self.feature_extractor(x))

    def predict_reward(self, x):
        with torch.no_grad():
            raw_score = self.score_predictor(self.feature_extractor(x))
            return torch.clamp(raw_score, self.score_min, self.score_max)

def mixup_data(x, y, alpha=MIXUP_ALPHA, device='cpu'):
    lam   = np.random.beta(alpha, alpha) if alpha > 0 else 1
    index = torch.randperm(x.size(0)).to(device)
    mixed_x = lam * x + (1 - lam) * x[index]
    return mixed_x, y, y[index], lam

def mixup_criterion(criterion, pred, y_a, y_b, lam):
    return lam * criterion(pred, y_a) + (1 - lam) * criterion(pred, y_b)

def custom_loss(pred, target):
    mse_loss    = F.mse_loss(pred, target)
    var_penalty = -0.1 * torch.var(pred)
    batch_size  = pred.size(0)

    if batch_size > 1:
        pred_i   = pred.view(-1, 1).repeat(1, batch_size).view(-1)
        pred_j   = pred.repeat(batch_size)
        target_i = target.view(-1, 1).repeat(1, batch_size).view(-1)
        target_j = target.repeat(batch_size)

        pred_diff   = pred_i - pred_j
        target_diff = target_i - target_j
        valid_pairs = (target_diff != 0).float()

        if valid_pairs.sum() > 0:
            rank_loss = torch.sum(
                valid_pairs * F.relu(-(pred_diff * target_diff) + 0.1)
            ) / (valid_pairs.sum() + 1e-8)
            return mse_loss + var_penalty + 0.2 * rank_loss

    return mse_loss + var_penalty

def apply_oversampling(df, threshold=10, target_count=15):
    score_counts = Counter(df['score'])
    rare_scores  = [s for s, c in score_counts.items() if c < threshold]
    oversampled_df = df.copy()

    for score in rare_scores:
        score_samples = df[df['score'] == score]
        copies_needed = max(0, target_count - len(score_samples))
        if copies_needed > 0 and len(score_samples) > 0:
            resampled = score_samples.sample(n=copies_needed, replace=True, random_state=42)
            oversampled_df = pd.concat([oversampled_df, resampled], ignore_index=True)

    return oversampled_df

def load_data():
    df = pd.read_excel(EXCEL_PATH)
    score_range  = (df['score'].min(), df['score'].max())
    df_oversampled = apply_oversampling(df, threshold=10, target_count=15)
    train_df, val_df = train_test_split(df_oversampled, test_size=0.3, random_state=42)

    train_transform = transforms.Compose([
        transforms.Resize((256, 256)),
        transforms.RandomCrop((224, 224)),
        transforms.RandomHorizontalFlip(),
        transforms.RandomRotation(15),
        transforms.ColorJitter(brightness=0.3, contrast=0.3, saturation=0.3, hue=0.1),
        transforms.RandomGrayscale(p=0.05),
        transforms.RandomAutocontrast(p=0.2),
        transforms.RandomAdjustSharpness(sharpness_factor=2, p=0.2),
        transforms.GaussianBlur(kernel_size=3, sigma=(0.1, 2.0)),
        transforms.RandomPerspective(distortion_scale=0.2, p=0.2),
        transforms.ToTensor(),
        transforms.RandomErasing(p=0.1, scale=(0.02, 0.1)),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
    ])

    val_transform = transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),
    ])

    train_loader = DataLoader(
        CTImageDataset(train_df, IMAGE_DIR, train_transform),
        batch_size=BATCH_SIZE, shuffle=True, num_workers=4, pin_memory=True,
    )
    val_loader = DataLoader(
        CTImageDataset(val_df, IMAGE_DIR, val_transform),
        batch_size=BATCH_SIZE, shuffle=False, num_workers=4, pin_memory=True,
    )

    return train_loader, val_loader, score_range

def train_reward_model():
    train_loader, val_loader, score_range = load_data()

    model     = EfficientNetV2RewardModel(score_range=score_range).to(DEVICE)
    optimizer = Adam(model.parameters(), lr=LEARNING_RATE, weight_decay=1e-4)
    scheduler = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(
        optimizer, T_0=10, T_mult=2, eta_min=1e-6
    )

    for epoch in range(NUM_EPOCHS):
        model.train()
        for images, scores in tqdm(train_loader, desc=f"Epoch {epoch+1}/{NUM_EPOCHS}"):
            images, scores = images.to(DEVICE), scores.to(DEVICE)
            optimizer.zero_grad()

            if np.random.random() < MIXUP_PROB:
                mixed_images, scores_a, scores_b, lam = mixup_data(
                    images, scores, alpha=MIXUP_ALPHA, device=DEVICE
                )
                outputs = model(mixed_images).squeeze()
                loss = mixup_criterion(F.mse_loss, outputs, scores_a, scores_b, lam)
            else:
                outputs = model(images).squeeze()
                loss = custom_loss(outputs, scores)

            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
            optimizer.step()

        scheduler.step()

    return model

if __name__ == "__main__":
    train_reward_model()
