class AdaptiveFeatureFusion(nn.Module):
    def __init__(self, channels, reduction=16):
        super().__init__()
        self.local_attention = nn.Sequential(
            nn.Conv2d(channels, channels, kernel_size=1),
            nn.BatchNorm2d(channels),
            nn.ReLU(inplace=True),
        )
        self.global_attention = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(channels, channels // reduction, kernel_size=1),
            nn.BatchNorm2d(channels // reduction),
            nn.ReLU(inplace=True),
            nn.Conv2d(channels // reduction, channels, kernel_size=1),
            nn.BatchNorm2d(channels),
        )
        self.sigmoid = nn.Sigmoid()

    def forward(self, x1, x2):
        x = x1 + x2
        attention = self.sigmoid(self.local_attention(x) + self.global_attention(x))
        return x1 * attention + x2 * (1 - attention)


class UNetAFFAdapter(nn.Module):
    def __init__(self, unet, channels_dict=None):
        super().__init__()
        self.unet = unet
        if channels_dict is None:
            channels_dict = {
                "down_0": 320,
                "down_1": 640,
                "down_2": 1280,
                "mid":    1280,
                "up_0":   1280,
                "up_1":   640,
            }
        self.aff_modules = nn.ModuleDict({
            "mid_down_2":  AdaptiveFeatureFusion(channels_dict["mid"]),
            "up_0_down_1": AdaptiveFeatureFusion(channels_dict["up_0"]),
            "up_1_down_0": AdaptiveFeatureFusion(channels_dict["up_1"]),
        })
        self.skip_features = {}
        self._register_hooks()

    def apply_aff(self, x, step):
        if step == "mid_down_2" and "down_2" in self.skip_features:
            return self.aff_modules["mid_down_2"](x, self.skip_features["down_2"])
        elif step == "up_0_down_1" and "down_1" in self.skip_features:
            return self.aff_modules["up_0_down_1"](x, self.skip_features["down_1"])
        elif step == "up_1_down_0" and "down_0" in self.skip_features:
            return self.aff_modules["up_1_down_0"](x, self.skip_features["down_0"])
        return x

    def _register_hooks(self):
        def get_down_hook(idx):
            def hook(module, input, output):
                feat = output[0] if isinstance(output, tuple) else output
                self.skip_features[f"down_{idx}"] = feat
            return hook

        def mid_hook(module, input, output):
            feat = output[0] if isinstance(output, tuple) else output
            self.skip_features["mid"] = feat
            fused = self.apply_aff(feat, "mid_down_2")
            return (fused,) + output[1:] if isinstance(output, tuple) else fused

        def get_up_hook(step_name):
            def hook(module, input, output):
                feat = output[0] if isinstance(output, tuple) else output
                fused = self.apply_aff(feat, step_name)
                return (fused,) + output[1:] if isinstance(output, tuple) else fused
            return hook

        if hasattr(self.unet, "down_blocks"):
            for i, block in enumerate(self.unet.down_blocks):
                block.register_forward_hook(get_down_hook(i))

        if hasattr(self.unet, "mid_block"):
            self.unet.mid_block.register_forward_hook(mid_hook)

        if hasattr(self.unet, "up_blocks"):
            for i, step_name in {0: "up_0_down_1", 1: "up_1_down_0"}.items():
                if i < len(self.unet.up_blocks):
                    self.unet.up_blocks[i].register_forward_hook(get_up_hook(step_name))

    def forward(self, x, timesteps, encoder_hidden_states):
        self.skip_features = {}
        return self.unet(x, timesteps, encoder_hidden_states)


processed_data_dir = "processed_CT_data_for_training"
base_model_id      = "Nihirc/Prompt2MedImage"
metadata_file      = "metadata.xlsx"

resolution                  = 512
train_batch_size            = 32
learning_rate               = 3e-4
max_train_steps             = 2000
gradient_accumulation_steps = 1
rank                        = 32
alpha                       = 64
validation_steps            = 100
num_workers                 = 8
validation_split            = 0.1
perceptual_weight           = 0.08
perceptual_layers           = [2, 7, 12, 21, 30]
aff_reduction               = 10

device       = torch.device("cuda")
weight_dtype = torch.float16

pipe = StableDiffusionPipeline.from_pretrained(
    base_model_id,
    torch_dtype=weight_dtype,
    safety_checker=None,
    requires_safety_checker=False,
)

tokenizer       = pipe.tokenizer
text_encoder    = pipe.text_encoder
vae             = pipe.vae
unet_base       = pipe.unet
noise_scheduler = pipe.scheduler

del pipe
gc.collect()
torch.cuda.empty_cache()

text_encoder = text_encoder.to(device, dtype=weight_dtype)
vae          = vae.to(device, dtype=weight_dtype)
unet_base    = unet_base.to(device, dtype=weight_dtype)

vae.requires_grad_(False)
text_encoder.requires_grad_(False)

vgg16 = models.vgg16(pretrained=True).features.to(device)
for param in vgg16.parameters():
    param.requires_grad = False
vgg16.eval()


def get_features(x):
    x = x.to(torch.float32)
    x = (x + 1) / 2.0
    x = x.repeat(1, 3, 1, 1) if x.shape[1] == 1 else x[:, :3]
    mean = torch.tensor([0.485, 0.456, 0.406]).view(1, 3, 1, 1).to(device)
    std  = torch.tensor([0.229, 0.224, 0.225]).view(1, 3, 1, 1).to(device)
    x = (x - mean) / std
    features = {}
    for i, layer in enumerate(vgg16):
        x = layer(x)
        if i in perceptual_layers:
            features[i] = x
    return features


def perceptual_loss(pred, target):
    pred_f, target_f = get_features(pred), get_features(target)
    return sum(F.mse_loss(pred_f[l], target_f[l]) for l in perceptual_layers if l in pred_f)


aff_adapter = UNetAFFAdapter(
    unet=unet_base,
    channels_dict={"down_0": 320, "down_1": 640, "down_2": 1280,
                   "mid": 1280, "up_0": 1280, "up_1": 640},
).to(device)

lora_config = LoraConfig(
    r=rank,
    lora_alpha=alpha,
    target_modules=[
        "to_k", "to_q", "to_v", "to_out.0",
        "conv1", "conv2",
        "proj_in", "proj_out", "conv_in", "conv_out",
        "attn2.to_k", "attn2.to_q", "attn2.to_v", "attn2.to_out.0",
    ],
    lora_dropout=0.1,
    bias="none",
)
unet_lora = get_peft_model(unet_base, lora_config)

metadata_path = os.path.join(processed_data_dir, metadata_file)
image_dir     = os.path.join(processed_data_dir, "images")

df = pd.read_excel(metadata_path)
df = df.drop_duplicates().dropna(subset=["file_name", "text"])

train_df, val_df = train_test_split(df, test_size=validation_split, random_state=42)


def get_train_transforms():
    return transforms.Compose([
        transforms.Resize((resolution, resolution)),
        transforms.RandomHorizontalFlip(p=0.5),
        transforms.ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.247, 0.247, 0.247], std=[0.223, 0.223, 0.223]),
    ])


def get_val_transforms():
    return transforms.Compose([
        transforms.Resize((resolution, resolution)),
        transforms.ToTensor(),
        transforms.Normalize(mean=[0.247, 0.247, 0.247], std=[0.223, 0.223, 0.223]),
    ])


class CTDataset(torch.utils.data.Dataset):
    def __init__(self, df, tokenizer, img_dir, transform):
        self.df        = df.reset_index(drop=True)
        self.tokenizer = tokenizer
        self.img_dir   = img_dir
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        row   = self.df.iloc[idx]
        image = Image.open(os.path.join(self.img_dir, row["file_name"])).convert("RGB")
        image = self.transform(image)
        text_inputs = self.tokenizer(
            row["text"],
            padding="max_length",
            max_length=self.tokenizer.model_max_length,
            truncation=True,
            return_tensors="pt",
        )
        return {"pixel_values": image, "input_ids": text_inputs.input_ids[0]}


train_dataset = CTDataset(train_df, tokenizer, image_dir, get_train_transforms())
val_dataset   = CTDataset(val_df,   tokenizer, image_dir, get_val_transforms())

train_dataloader = torch.utils.data.DataLoader(
    train_dataset, batch_size=train_batch_size, shuffle=True,
    num_workers=num_workers, pin_memory=True, drop_last=True,
)
val_dataloader = torch.utils.data.DataLoader(
    val_dataset, batch_size=train_batch_size, shuffle=False,
    num_workers=num_workers, pin_memory=True,
)


def validate():
    unet_lora.eval()
    aff_adapter.eval()
    val_loss, val_steps = 0.0, 0
    with torch.no_grad():
        for batch in val_dataloader:
            pixel_values = batch["pixel_values"].to(device, dtype=weight_dtype)
            input_ids    = batch["input_ids"].to(device)
            encoder_hidden_states = text_encoder(input_ids)[0]
            latents = vae.encode(pixel_values).latent_dist.sample() * vae.config.scaling_factor
            noise         = torch.randn_like(latents)
            timesteps     = torch.randint(0, noise_scheduler.config.num_train_timesteps,
                                          (latents.shape[0],), device=device).long()
            noisy_latents = noise_scheduler.add_noise(latents, noise, timesteps)
            aff_adapter.skip_features = {}
            model_pred = unet_lora(noisy_latents, timesteps, encoder_hidden_states).sample
            mse  = F.mse_loss(model_pred, noise, reduction="mean")
            perc = perceptual_loss(model_pred, noise)
            val_loss  += (mse + perceptual_weight * perc).item()
            val_steps += 1
    return val_loss / val_steps if val_steps > 0 else float("inf")


trainable_params = (
    [p for p in unet_lora.parameters() if p.requires_grad]
    + list(aff_adapter.aff_modules.parameters())
)

optimizer = torch.optim.AdamW(trainable_params, lr=learning_rate, weight_decay=5e-5)

lr_scheduler = get_scheduler(
    "cosine_with_restarts",
    optimizer=optimizer,
    num_warmup_steps=int(0.05 * max_train_steps),
    num_training_steps=max_train_steps // gradient_accumulation_steps,
    num_cycles=3,
)

scaler       = torch.amp.GradScaler()
global_step  = 0
progress_bar = tqdm(total=max_train_steps)

for epoch in range(999):
    unet_lora.train()
    aff_adapter.train()

    for step, batch in enumerate(train_dataloader):
        pixel_values = batch["pixel_values"].to(device, dtype=weight_dtype)
        input_ids    = batch["input_ids"].to(device)

        with torch.no_grad():
            encoder_hidden_states = text_encoder(input_ids)[0]
            latents = vae.encode(pixel_values).latent_dist.sample() * vae.config.scaling_factor

        noise         = torch.randn_like(latents)
        timesteps     = torch.randint(0, noise_scheduler.config.num_train_timesteps,
                                      (latents.shape[0],), device=device).long()
        noisy_latents = noise_scheduler.add_noise(latents, noise, timesteps)

        with torch.cuda.amp.autocast():
            aff_adapter.skip_features = {}
            model_pred = unet_lora(noisy_latents, timesteps, encoder_hidden_states).sample
            mse  = F.mse_loss(model_pred, noise, reduction="mean")
            perc = perceptual_loss(model_pred, noise)
            loss = (mse + perceptual_weight * perc) / gradient_accumulation_steps

        scaler.scale(loss).backward()

        if (step + 1) % gradient_accumulation_steps == 0 or step == len(train_dataloader) - 1:
            scaler.unscale_(optimizer)
            torch.nn.utils.clip_grad_norm_(trainable_params, 1.0)
            scaler.step(optimizer)
            scaler.update()
            lr_scheduler.step()
            optimizer.zero_grad()
            global_step += 1
            progress_bar.update(1)

            if global_step % validation_steps == 0:
                validate()
                unet_lora.train()
                aff_adapter.train()

        if global_step >= max_train_steps:
            break

    if global_step >= max_train_steps:
        break
